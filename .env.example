# URL of the deployed (or local dev) FinDocGPT API
FINDOCGPT_API_URL=http://localhost:8000

# Which LLM backend the planner/self-critic use: "ollama" (free, local, default) or "claude" (paid)
LLM_BACKEND=ollama
ANTHROPIC_API_KEY=

OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
# See findocgpt/.env for why this is 0 on this machine (6GB VRAM GPU).
OLLAMA_NUM_GPU=0
